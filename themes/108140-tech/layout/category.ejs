<%
const categoryPosts = page.posts ? page.posts.toArray() : [];
%>
<main class="listing-page">
  <section class="listing-head">
    <p class="section-kicker">Category</p>
    <h1><%= page.category || page.title || "分类" %></h1>
    <p>这个分类下共有 <%= categoryPosts.length %> 篇文章。</p>
  </section>

  <section class="archive-list">
    <% categoryPosts.forEach(function(post) { %>
      <article class="archive-card">
        <time datetime="<%= date_xml(post.date) %>"><%= date(post.date, "YYYY.MM.DD") %></time>
        <h2><a href="<%- url_for(post.path) %>"><%= post.title %></a></h2>
        <p><%= post.summary || strip_html(post.excerpt || post.content || "").replace(/\s+/g, " ").trim().slice(0, 120) %></p>
      </article>
    <% }) %>
  </section>
</main>
