<%
const posts = page.posts ? page.posts.toArray() : site.posts.sort("date", -1).toArray();
const allPosts = site.posts.sort("date", -1).toArray();
const featured = allPosts.find(function(post) { return post.featured; }) || allPosts[0];
const rest = allPosts.filter(function(post) { return !featured || post._id !== featured._id; });
const heroImage = theme.hero_image || "/assets/hero.png";
function tagsOf(post) {
  return post.tags ? post.tags.toArray().map(function(tag) { return tag.name; }) : [];
}
function postSummary(post) {
  return post.summary || strip_html(post.excerpt || post.content || "").replace(/\s+/g, " ").trim().slice(0, 130);
}
function imageOf(post) {
  const image = post.image || heroImage;
  return /^https?:\/\//.test(image) || image.startsWith("/") ? image : `/${image}`;
}
const tagCounts = {};
allPosts.forEach(function(post) {
  tagsOf(post).forEach(function(tag) {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  });
});
const sortedTags = Object.keys(tagCounts).sort(function(a, b) {
  return tagCounts[b] - tagCounts[a] || a.localeCompare(b, "zh-CN");
});
function card(post, featuredCard) {
  const tags = tagsOf(post);
%>
  <article class="post-card <%= featuredCard ? "featured-post" : "list-post" %>" data-title="<%= post.title %>" data-tags="<%= tags.join(" ") %>">
    <% if (featuredCard) { %>
      <a class="post-image" href="<%- url_for(post.path) %>">
        <img src="<%- url_for(imageOf(post)) %>" alt="<%= post.imageAlt || post.title %>">
      </a>
    <% } else { %>
      <div class="post-date-block">
        <strong><%= date(post.date, "DD") %></strong>
        <span><%= date(post.date, "YYYY.MM") %></span>
      </div>
    <% } %>
    <div class="post-body">
      <div class="post-meta">
        <% if (featuredCard) { %><span>置顶</span><% } %>
        <time datetime="<%= date_xml(post.date) %>"><%= date(post.date, "YYYY.MM.DD") %></time>
        <% if (post.readingTime) { %><span><%= post.readingTime %></span><% } %>
      </div>
      <h3><a href="<%- url_for(post.path) %>"><%= post.title %></a></h3>
      <p><%= postSummary(post) %></p>
      <div class="tag-list">
        <% tags.forEach(function(tag) { %>
          <span><%= tag %></span>
        <% }) %>
      </div>
    </div>
  </article>
<%
}
%>

<main>
  <section class="hero" aria-label="<%= config.title %>">
    <img src="<%- url_for(heroImage) %>" alt="信息技术博客背景图">
    <div class="hero-shade"></div>
    <div class="hero-content">
      <div class="hero-main">
        <p class="eyebrow">Hexo Technology Blog</p>
        <h1><%= config.title %></h1>
        <p class="hero-copy">把信息技术、数学推导、命令配置、故障排查和工具实践整理成可以长期维护的 Markdown 技术文章。</p>
        <div class="hero-topics" aria-label="内容方向">
          <% ["网络", "Linux", "云服务", "安全", "数学", "AI", "工具链"].forEach(function(topic) { %>
            <span><%= topic %></span>
          <% }) %>
        </div>
      </div>

      <aside class="hero-panel" aria-label="站点概览">
        <span class="panel-label">Latest</span>
        <strong><%= allPosts[0] ? allPosts[0].title : "准备写第一篇文章" %></strong>
        <a href="#latest">进入文章流</a>
        <dl class="site-metrics">
          <div><dt>文章</dt><dd><%= allPosts.length %></dd></div>
          <div><dt>标签</dt><dd><%= sortedTags.length %></dd></div>
          <div><dt>引擎</dt><dd>Hexo</dd></div>
        </dl>
        <div class="pipeline">
          <% ["Markdown", "LaTeX", "KaTeX", "GitHub Actions"].forEach(function(item) { %>
            <span><%= item %></span>
          <% }) %>
        </div>
      </aside>
    </div>
  </section>

  <div class="blog-shell">
    <section id="latest" class="feed-column" aria-labelledby="latest-title">
      <div class="section-head">
        <div>
          <p class="section-kicker">Latest Posts</p>
          <h2 id="latest-title">技术文章</h2>
        </div>
        <label class="search-box">
          <span>搜索文章</span>
          <input id="post-search" type="search" placeholder="DNS、Linux、AI、π、部署">
        </label>
      </div>

      <div class="filter-row" aria-label="文章筛选">
        <button class="filter-button is-active" type="button" data-filter="all" aria-pressed="true">全部</button>
        <% sortedTags.forEach(function(tag) { %>
          <button class="filter-button" type="button" data-filter="<%= tag %>" aria-pressed="false"><%= tag %></button>
        <% }) %>
      </div>

      <% if (featured) { card(featured, true); } %>

      <div class="post-list">
        <% rest.forEach(function(post) { card(post, false); }) %>
      </div>

      <p id="empty-state" class="empty-state" hidden>没有找到匹配的文章。</p>
    </section>

    <aside class="site-sidebar" aria-label="博客侧栏">
      <section class="side-panel author-panel">
        <p class="side-kicker">Author</p>
        <h2><%= config.author %></h2>
        <p>记录信息技术实践：网络、系统、部署、排障、数学、工具链和 AI 自动化。</p>
      </section>

      <section class="side-panel">
        <p class="side-kicker">Tags</p>
        <h2>标签云</h2>
        <div class="tag-cloud">
          <% sortedTags.forEach(function(tag) { %>
            <a href="#latest" data-tag-link="<%= tag %>"><span><%= tag %></span><strong><%= tagCounts[tag] %></strong></a>
          <% }) %>
        </div>
      </section>

      <section class="side-panel">
        <p class="side-kicker">Archive</p>
        <h2>归档</h2>
        <% allPosts.slice(0, 8).forEach(function(post) { %>
          <div class="archive-row">
            <a href="<%- url_for(post.path) %>"><%= post.title %></a>
            <strong><%= date(post.date, "MM.DD") %></strong>
          </div>
        <% }) %>
      </section>
    </aside>
  </div>

  <section class="topic-section" aria-labelledby="topics-title">
    <div class="section-head">
      <div>
        <p class="section-kicker">Topics</p>
        <h2 id="topics-title">专题目录</h2>
      </div>
      <a class="rss-link" href="<%- url_for("/atom.xml") %>">RSS 订阅</a>
    </div>
    <div class="topic-grid">
      <% sortedTags.forEach(function(tag) {
        const related = allPosts.filter(function(post) { return tagsOf(post).includes(tag); }).slice(0, 3);
      %>
        <article class="topic-card">
          <div class="topic-card-head">
            <span><%= tag %></span>
            <strong><%= tagCounts[tag] %></strong>
          </div>
          <ul>
            <% related.forEach(function(post) { %>
              <li><a href="<%- url_for(post.path) %>"><%= post.title %></a></li>
            <% }) %>
          </ul>
        </article>
      <% }) %>
    </div>
  </section>
</main>
